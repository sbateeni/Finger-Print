# Telegram bot (@BotFather) — leave empty to run web-only
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ENABLED=1

# Optional: restrict who can use the bot (comma-separated user or chat IDs)
# Get your ID from @userinfobot
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Send web UI analysis results to these chats (defaults to TELEGRAM_ALLOWED_CHAT_IDS)
TELEGRAM_NOTIFY_ON_WEB=1
# TELEGRAM_NOTIFY_CHAT_IDS=123456789

# Embed bot in web server (1 = single process + shared wait queue). 0 = separate python -m bot
TELEGRAM_EMBEDDED=1

# Telegram: deep analysis = same engine as web + auto alignment search before match
TELEGRAM_DEEP_ANALYSIS=1
# wide = more zoom/shift combinations (slower, closer to manual tuning); quick = faster
TELEGRAM_SWEEP_MODE=wide

# SSL for httpx on Windows if needed: TELEGRAM_SSL_VERIFY=0
# Web dev live reload (optional)
LIVE_RELOAD=1

# Auto-update from GitHub (fetch + fast-forward pull when behind)
AUTO_GIT_UPDATE=1
# 0 = check only at startup; e.g. 3600 = every hour
AUTO_GIT_UPDATE_INTERVAL_SEC=0
# Skip pull if you have uncommitted changes (recommended)
AUTO_GIT_UPDATE_ALLOW_DIRTY=0
AUTO_GIT_REMOTE=origin
