# === Telegram (@BotFather) — اتركه فارغاً لتشغيل الويب فقط ===
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ENABLED=1
TELEGRAM_ALLOWED_CHAT_IDS=123456789

TELEGRAM_NOTIFY_ON_WEB=1
TELEGRAM_EMBEDDED=1
TELEGRAM_DEEP_ANALYSIS=1
TELEGRAM_SWEEP_MODE=wide

# وضع الفحص الافتراضي للويب: deep | fast
DEFAULT_ANALYSIS_MODE=deep
# 1 = بحث Zoom/Shift واسع في الفحص العميق (بطيء). 0 = عميق بدون بحث مسبق
DEEP_AUTO_ALIGN_SWEEP=1

# === Linux / Kali — ./run_dev.sh ===
HOST=0.0.0.0
PORT=8000
# 0 = مستقر (موصى به). 1 = إعادة تحميل تلقائية للتطوير
LIVE_RELOAD=0

# سحب آخر تحديث من GitHub عند كل تشغيل
AUTO_GIT_UPDATE=1
AUTO_GIT_UPDATE_INTERVAL_SEC=0
AUTO_GIT_UPDATE_ALLOW_DIRTY=0
AUTO_GIT_REMOTE=origin

# 1 = دمج المفاتيح الناقصة من .env.example إلى .env عند run_dev
AUTO_SYNC_ENV=1

# === Windows — .\run_dev.ps1 أو run_dev.bat ===
# HOST=127.0.0.1
# لا تشغّل نفس TELEGRAM_BOT_TOKEN على Kali و Windows معاً (409 Conflict)

# Matching / fusion (ORB off — weak on fingerprints)
USE_ORB_FUSION=0
USE_CORE_ALIGNMENT=1
USE_TRIPLET_ALIGNMENT=0
USE_PYFING_EXTRACTION=0
ENABLE_EXTENDED_MINUTIAE=1
MINUTIAE_MATCH_IGNORE_TYPES=dot,lake
MATCH_ENGINE_THRESHOLD=40
QUALITY_GATE_ENABLED=1
QUALITY_GATE_MIN_SCORE=40
QUALITY_BACKEND=auto
# NFIQ2_CLI_PATH=C:/Program Files/NFIQ 2/nfiq2.exe
# Optional ML: pip install -r requirements-ml.txt then USE_PYFING_EXTRACTION=1

# Windows فقط عند خطأ SSL:
# TELEGRAM_SSL_VERIFY=0
