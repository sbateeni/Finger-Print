# Telegram bot (@BotFather) — leave empty to run web-only
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ENABLED=1
TELEGRAM_AUTO_SWEEP=1
TELEGRAM_SWEEP_MODE=quick

# Optional: restrict who can use the bot (comma-separated user or chat IDs)
# Get your ID from @userinfobot
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# SSL for httpx on Windows if needed: TELEGRAM_SSL_VERIFY=0
# Web dev live reload (optional)
LIVE_RELOAD=1

# Auto-update from GitHub (fetch + fast-forward pull when behind)
AUTO_GIT_UPDATE=1
USE_BOZORTH_MATCHER=1
# 0 = check only at startup; e.g. 3600 = every hour
AUTO_GIT_UPDATE_INTERVAL_SEC=0
# Skip pull if you have uncommitted changes (recommended)
AUTO_GIT_UPDATE_ALLOW_DIRTY=0
AUTO_GIT_REMOTE=origin
