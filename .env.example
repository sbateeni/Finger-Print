# Telegram bot (@BotFather) — leave empty to run web-only
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ENABLED=1
TELEGRAM_ALLOWED_CHAT_IDS=123456789

TELEGRAM_NOTIFY_ON_WEB=1
TELEGRAM_EMBEDDED=1
TELEGRAM_DEEP_ANALYSIS=1
TELEGRAM_SWEEP_MODE=wide

# Linux / Kali — use ./run_dev.sh (git pull + web + Telegram)
HOST=0.0.0.0
PORT=8000
# 0 = stable on Kali (recommended). 1 = dev auto-reload
LIVE_RELOAD=0

AUTO_GIT_UPDATE=1
AUTO_GIT_UPDATE_INTERVAL_SEC=0
AUTO_GIT_UPDATE_ALLOW_DIRTY=0
AUTO_GIT_REMOTE=origin

# 1 = merge missing keys from .env.example into .env on each run_dev (default)
AUTO_SYNC_ENV=1

# Matching / fusion (ORB off by default — weak on fingerprints)
USE_ORB_FUSION=0
USE_CORE_ALIGNMENT=1
USE_TRIPLET_ALIGNMENT=0
USE_PYFING_EXTRACTION=0
MATCH_ENGINE_THRESHOLD=40
QUALITY_GATE_ENABLED=1
QUALITY_GATE_MIN_SCORE=40
QUALITY_BACKEND=auto
# NFIQ2_CLI_PATH=C:/Program Files/NFIQ 2/nfiq2.exe

# Optional: pip install -r requirements-ml.txt  (pyfing + tensorflow)

# Windows SSL only: TELEGRAM_SSL_VERIFY=0
